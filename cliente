  document.getElementById("checkout-title").textContent=modoCompra==="individual"?"Compra individual":"Unirme al grupo";
  document.getElementById("tipo-compra-banner").innerHTML=modoCompra==="individual"?
    `<div style="background:#fef9c3;border:1.5px solid #fde68a;border-radius:12px;padding:12px;font-size:12px;color:#854d0e;display:flex;gap:8px;align-items:center;"><span style="font-size:20px;">🛒</span><div><b>Compra individual · sin descuento</b><br>Únete a un grupo para 10% OFF</div></div>`:
    `<div style="background:var(--gl);border:1.5px solid var(--gb);border-radius:12px;padding:12px;font-size:12px;color:var(--gd);display:flex;gap:8px;align-items:center;"><span style="font-size:20px;">👥</span><div><b>Compra grupal${tieneDesc?" · 10% OFF":""}</b><br>Invita vecinos para activar el descuento</div></div>`;
  document.getElementById("resumen-items").innerHTML=`
    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bdr);font-size:13px;"><span>${productoActual.emoji} ${productoActual.product_name}</span><span>S/${pN}/${productoActual.unit||"kg"}</span></div>
    ${modoCompra==="grupal"&&tieneDesc?`<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bdr);font-size:13px;"><span>Precio grupal (5 vecinos)</span><span style="color:var(--g);">S/${pG}/${productoActual.unit||"kg"}</span></div>`:""}
    <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:15px;font-weight:700;"><span>Total</span><span style="color:var(--g);">S/${modoCompra==="grupal"&&tieneDesc?pG:pN}/${productoActual.unit||"kg"}</span></div>`;
  if(modoCompra==="grupal"&&tieneDesc) document.getElementById("desc-info-box").innerHTML=`<div style="background:var(--gl);border:1.5px solid var(--gb);border-radius:10px;padding:10px;text-align:center;"><div style="font-family:'Syne',sans-serif;font-size:13px;font-weight:900;color:var(--gd);">🎉 Con 5 vecinos → S/${pG}/${productoActual.unit||"kg"}</div><div style="font-size:11px;color:var(--mut);">Comparte con tus vecinos para activar el 10% OFF</div></div>`;
  else document.getElementById("desc-info-box").innerHTML="";
}

window.previewFile=function(input){ const f=input.files[0]; if(!f) return; fileData=f; const r=new FileReader(); r.onload=e=>{const p=document.getElementById("upload-preview"); p.src=e.target.result; p.style.display="block";}; r.readAsDataURL(f); };

window.confirmarPedido=async function(){
  const nombre=document.getElementById("c-nombre").value.trim();
  const tel=document.getElementById("c-tel").value.trim();
  const sector=document.getElementById("c-sector").value.trim();
  if(!nombre||!tel||!sector){toast("⚠ Completa todos los campos");return;}
  if(!productoActual){toast("⚠ Error: no hay producto");return;}
  const btn=document.getElementById("btn-confirmar"); btn.disabled=true; btn.textContent="Procesando...";
  try{
    let shotUrl="";
    if(fileData){ try{ const fd=new FormData(); fd.append("file",fileData); fd.append("upload_preset","grupay_unsigned"); fd.append("folder","grupay/proofs"); const res=await fetch("https://api.cloudinary.com/v1_1/dyi3mbeqo/image/upload",{method:"POST",body:fd}); const j=await res.json(); if(j.secure_url) shotUrl=j.secure_url; }catch(e){} }
    const pN=productoActual.price_per_unit||0, tieneDesc=productoActual.has_discount!==false;
    const pG=tieneDesc?Math.round(pN*0.9*10)/10:pN;
    const esInd=modoCompra==="individual";
    // Actualizar sector
    let sectorId="";
    if(!esInd){
      const sectRef=collection(db,"grupay_groups",productoActual.id,"sectors");
      const sSnap=await getDocs(sectRef);
      let sDoc=null; sSnap.forEach(d=>{ if((d.data().sector_name||"").toLowerCase()===sector.toLowerCase()) sDoc={id:d.id,...d.data()}; });
      if(sDoc){ sectorId=sDoc.id; await updateDoc(doc(db,"grupay_groups",productoActual.id,"sectors",sDoc.id),{member_count:increment(1),status:(sDoc.member_count||0)+1>=5?"active":"open"}); }
      else{ const nd=await addDoc(sectRef,{sector_name:sector,member_count:1,status:"open",created_at:serverTimestamp(),lider_nombre:nombre,lider_tel:tel}); sectorId=nd.id; }
      await addDoc(collection(db,"grupay_groups",productoActual.id,"sectors",sectorId,"members"),{nombre,tel,sector,payment_status:"uploaded",payment_screenshot_url:shotUrl,joined_at:serverTimestamp()});
    }
    const pedRef=await addDoc(collection(db,"grupay_pedidos"),{nombre,tel,sector,producto_id:productoActual.id,producto_nombre:productoActual.product_name,producto_emoji:productoActual.emoji||"📦",precio_normal:pN,precio_final:esInd?pN:pG,sector_id:sectorId,tipo_compra:esInd?"individual":"grupal",payment_status:"uploaded",payment_screenshot_url:shotUrl,fecha:serverTimestamp()});
    window.open(`https://wa.me/51948115030?text=${encodeURIComponent(`${esInd?"🛒 INDIVIDUAL":"👥 GRUPAL"} GruPay\n👤 ${nombre} (${tel})\n📍 ${sector}\n🛍 ${productoActual.emoji} ${productoActual.product_name}\n📸 ${shotUrl?"✅":"⚠ Sin captura"}`)}`, "_blank");
    historial.unshift({id:pedRef.id,product_name:productoActual.product_name,emoji:productoActual.emoji||"📦",sector,payment_status:"uploaded",tipo_compra:esInd?"individual":"grupal",fecha:new Date().toLocaleDateString("es-PE",{day:"numeric",month:"short"})});
    localStorage.setItem("gp_hist",JSON.stringify(historial));
    fileData=null; btn.disabled=false; btn.textContent="✅ Confirmar pedido";
    toast("✅ ¡Pedido registrado!"); setTimeout(()=>goScreen("pedidos"),1500);
  }catch(e){ toast("❌ "+e.message); btn.disabled=false; btn.textContent="✅ Confirmar pedido"; }
};

// ── HISTORIAL ──────────────────────────────────────────────────────────────
function renderHist(){
  const el=document.getElementById("hist-body");
  if(!historial.length){ el.innerHTML='<div class="empty"><span>📭</span>Aún no tienes pedidos</div>'; return; }
  el.innerHTML=historial.map((h,i)=>`<div class="hist-card">
    <div style="font-size:30px;">${h.emoji}</div>
    <div style="flex:1;"><div style="font-weight:700;font-size:13px;">${h.product_name}</div><div style="font-size:11px;color:var(--mut);">📍 ${h.sector} · ${h.fecha} · ${h.tipo_compra==="grupal"?"👥":"🛒"}</div></div>
    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
      <span style="font-size:10px;font-weight:700;padding:3px 8px;border-radius:99px;background:${h.payment_status==="verified"?"#dcfce7":"#fef9c3"};color:${h.payment_status==="verified"?"#15803d":"#854d0e"};">${h.payment_status==="verified"?"✅ Verificado":"⏳ Pendiente"}</span>
      ${h.payment_status!=="verified"?`<button onclick="eliminarPedido(${i})" style="background:none;border:none;font-size:11px;color:#ef4444;cursor:pointer;">🗑</button>`:""}
    </div>
  </div>`).join("");
}
window.eliminarPedido=function(i){ if(!confirm("¿Cancelar?")) return; historial.splice(i,1); localStorage.setItem("gp_hist",JSON.stringify(historial)); renderHist(); };

// ── PERFIL ─────────────────────────────────────────────────────────────────
function renderPerfil(){
  const el=document.getElementById("perfil-body");
  if(!usuarioActual){ el.innerHTML=`<div style="background:#fff;border-radius:16px;padding:24px;text-align:center;box-shadow:0 2px 12px rgba(0,0,0,.06);"><div style="font-size:52px;margin-bottom:10px;">👤</div><div style="font-family:'Syne',sans-serif;font-size:16px;font-weight:900;margin-bottom:14px;">No has iniciado sesión</div><button class="btn-confirmar" onclick="goScreen('login')" style="max-width:200px;margin:0 auto;">Iniciar sesión →</button></div>`; return; }
  const u=usuarioActual;
  el.innerHTML=`<div style="display:flex;flex-direction:column;gap:12px;">
    <div style="background:linear-gradient(135deg,#14532d,#166634);border-radius:16px;padding:20px;color:#fff;display:flex;align-items:center;gap:14px;">
      <div style="width:54px;height:54px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:26px;">${u.nombre?u.nombre[0].toUpperCase():"👤"}</div>
      <div><div style="font-family:'Syne',sans-serif;font-size:18px;font-weight:900;">${u.nombre}</div><div style="font-size:12px;opacity:.8;">📱 ${u.telefono_completo||u.telefono||"—"}</div></div>
    </div>
    <div style="background:#fff;border-radius:14px;padding:16px;box-shadow:0 2px 8px rgba(0,0,0,.06);">
      <div style="font-family:'Syne',sans-serif;font-size:14px;font-weight:900;margin-bottom:8px;">📦 Datos de entrega</div>
      <div style="font-size:13px;color:var(--mut);">📍 ${u.direccion||"No ingresada"}</div>
      <div style="font-size:13px;color:var(--mut);">🚪 ${u.referencia||"—"}</div>
      <div style="font-size:13px;color:var(--mut);">🕐 ${u.horario||"—"}</div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
      <div style="background:#fff;border-radius:14px;padding:14px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,.06);"><div style="font-family:'Syne',sans-serif;font-size:26px;font-weight:900;color:var(--g);">${historial.length}</div><div style="font-size:11px;color:var(--mut);">Pedidos</div></div>
      <div style="background:#fff;border-radius:14px;padding:14px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,.06);"><div style="font-family:'Syne',sans-serif;font-size:26px;font-weight:900;color:var(--g);">${historial.filter(h=>h.payment_status==="verified").length}</div><div style="font-size:11px;color:var(--mut);">Verificados ✅</div></div>
    </div>
    <button onclick="cerrarSesion()" style="width:100%;padding:13px;background:#fff;border:2px solid #fecaca;border-radius:12px;color:#dc2626;font-size:14px;font-weight:700;cursor:pointer;">🚪 Cerrar sesión</button>
  </div>`;
}
</script>
