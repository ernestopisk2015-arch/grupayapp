      <div style="display:flex;gap:16px;">
        <div><div style="font-size:10px;opacity:.7;">Individual</div><div style="font-size:18px;font-weight:900;">S/${pN}/${productoActual.unit||"kg"}</div></div>
        <div style="width:1px;background:rgba(255,255,255,.2);"></div>
        <div><div style="font-size:10px;opacity:.7;">5+ vecinos ✅</div><div style="font-size:18px;font-weight:900;color:#86efac;">S/${pG}/${productoActual.unit||"kg"}</div></div>
      </div>
    </div>`:`<div style="background:var(--gl);border:1.5px solid var(--gb);border-radius:12px;padding:12px;margin-bottom:4px;"><b>Precio fijo: S/${pN}/${productoActual.unit||"kg"}</b></div>`;
  document.getElementById("form-nuevo-sector").innerHTML="";
  goScreen("sectores");
  const el=document.getElementById("sectores-list");
  el.innerHTML='<div class="loading"><div class="spinner"></div><span>Buscando grupos...</span></div>';
  try{
    const snap=await getDocs(collection(db,"grupay_groups",gid,"sectors"));
    const sects=[]; snap.forEach(d=>sects.push({id:d.id,...d.data()}));
    if(!sects.length){ el.innerHTML='<div class="empty"><span>📍</span>Sin grupos aún</div>'; setTimeout(()=>mostrarFormNuevoSector(),400); return; }
    el.innerHTML=sects.map(s=>{
      const pct=Math.min((s.member_count||0)/5*100,100), act=(s.member_count||0)>=5;
      return `<div class="sector-card" onclick="seleccionarSector('${s.sector_name||s.id}')" style="${act?"background:var(--gl);":""}">
