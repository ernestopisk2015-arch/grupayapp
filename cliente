<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="GruPay">
<meta name="theme-color" content="#16a34a">
<link rel="manifest" href="/cliente/manifest.json">
<title>GruPay — Compra en grupo, ahorra en grande</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800;900&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{--g:#16a34a;--gd:#14532d;--gl:#f0fdf4;--gb:#bbf7d0;--r:#dc2626;--txt:#0f172a;--mut:#64748b;--bdr:#e2e8f0;--bg:#f8fafc;}
html,body{height:100%;background:var(--bg);color:var(--txt);font-family:'DM Sans',sans-serif;overflow:hidden;overscroll-behavior:none;}
#shell{display:flex;flex-direction:column;height:100vh;max-width:430px;margin:0 auto;background:var(--bg);}
.hdr{background:#fff;padding:10px 14px;display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid var(--bdr);flex-shrink:0;box-shadow:0 2px 12px rgba(0,0,0,.06);}
.logo{display:flex;align-items:center;gap:8px;}
.logo-ic{width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,#14532d,#16a34a);display:flex;align-items:center;justify-content:center;font-size:17px;}
.logo-t{font-family:'Syne',sans-serif;font-size:18px;font-weight:900;letter-spacing:-1px;line-height:1;}
.logo-t b{color:var(--g);}
.logo-s{font-size:9px;color:var(--mut);letter-spacing:.5px;font-weight:600;}
.screen{display:none;flex:1;overflow-y:auto;flex-direction:column;}
.screen.active{display:flex;}
#screen-inicio.active{display:block;}
.hero{background:linear-gradient(135deg,#14532d 0%,#166534 50%,#15803d 100%);padding:12px 16px 14px;position:relative;overflow:hidden;}
.hero-tag{background:rgba(255,255,255,.15);color:#fff;font-size:9px;font-weight:700;letter-spacing:1px;padding:3px 8px;border-radius:99px;display:inline-block;margin-bottom:6px;border:1px solid rgba(255,255,255,.2);}
.hero-title{font-family:'Syne',sans-serif;font-size:18px;font-weight:900;color:#fff;line-height:1.2;margin-bottom:8px;}
.hero-title span{color:#86efac;}
.hero-pills{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;}
.pill{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);color:#fff;font-size:10px;font-weight:600;padding:4px 8px;border-radius:99px;}
.hero-cta{display:flex;gap:8px;}
.btn-hero-primary{flex:1;padding:10px;background:#fff;color:var(--gd);border:none;border-radius:10px;font-size:12px;font-weight:800;cursor:pointer;font-family:'Syne',sans-serif;display:flex;align-items:center;justify-content:center;gap:6px;}
.btn-hero-sec{flex:1;padding:10px;background:rgba(255,255,255,.15);color:#fff;border:1.5px solid rgba(255,255,255,.3);border-radius:10px;font-size:12px;font-weight:700;cursor:pointer;}
.scroll-body{padding:14px;display:flex;flex-direction:column;gap:14px;}
.sec-row{display:flex;align-items:center;justify-content:space-between;}
.sec-t{font-family:'Syne',sans-serif;font-size:16px;font-weight:900;}
.sec-count{background:var(--gl);color:var(--gd);font-size:11px;font-weight:700;padding:3px 8px;border-radius:99px;border:1px solid var(--gb);}
.cat-row{display:flex;gap:8px;overflow-x:auto;padding-bottom:2px;}
.cat-row::-webkit-scrollbar{display:none;}
.cat-btn{flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:4px;padding:10px 14px;background:#fff;border:2px solid var(--bdr);border-radius:12px;cursor:pointer;min-width:72px;}
.cat-btn.on{background:var(--gl);border-color:var(--g);}
.cat-btn span:first-child{font-size:22px;}
.cat-btn span:last-child{font-size:10px;font-weight:700;color:var(--mut);white-space:nowrap;}
.cat-btn.on span:last-child{color:var(--gd);}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.pc{background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 2px 10px rgba(0,0,0,.07);position:relative;}
.pc:active{transform:scale(.97);}
.pc-img{width:100%;height:90px;object-fit:cover;}
.pc-img-em{width:100%;height:90px;background:linear-gradient(135deg,var(--gl),#dcfce7);display:flex;align-items:center;justify-content:center;font-size:42px;}
.ribbon{position:absolute;top:6px;right:6px;background:#dc2626;color:#fff;font-size:9px;font-weight:800;padding:2px 6px;border-radius:99px;}
.pc-bd{padding:8px 8px 4px;}
.pc-nm{font-weight:700;font-size:12px;line-height:1.3;margin-bottom:4px;}
.pc-pr{display:flex;align-items:baseline;gap:3px;}
.pc-pr-s{font-size:10px;font-weight:700;color:var(--g);}
.pc-pr-n{font-size:16px;font-weight:900;color:var(--g);font-family:'Syne',sans-serif;}
.pc-pr-u{font-size:9px;color:var(--mut);}
.pc-pr-old{font-size:10px;color:var(--mut);text-decoration:line-through;margin-left:2px;}
.pc-sub{font-size:9px;color:var(--g);font-weight:700;margin-top:2px;}
.pc-btns{display:flex;gap:6px;padding:6px 8px 8px;}
.btn-grupo{flex:1;padding:7px 4px;border:2px solid var(--gb);border-radius:8px;background:var(--gl);color:var(--gd);font-size:10px;font-weight:700;cursor:pointer;}
.btn-carrito{flex:1;padding:7px 4px;border:none;border-radius:8px;font-size:10px;font-weight:700;cursor:pointer;color:#fff;background:linear-gradient(135deg,var(--gd),var(--g));}
.btn-carrito.ya{background:#bbf7d0;color:var(--gd);}
.checkout-hdr{background:#fff;padding:12px 16px;display:flex;align-items:center;gap:10px;border-bottom:2px solid var(--bdr);flex-shrink:0;}
.checkout-back{background:none;border:none;font-size:20px;cursor:pointer;}
.checkout-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:900;}
.form-card{background:#fff;border-radius:14px;padding:14px;box-shadow:0 2px 10px rgba(0,0,0,.06);}
.form-label{font-size:12px;font-weight:700;color:var(--mut);margin-bottom:5px;display:block;}
.form-input{width:100%;padding:11px 13px;border:2px solid var(--bdr);border-radius:10px;font-size:15px;font-family:'DM Sans',sans-serif;outline:none;background:#fff;}
.form-input:focus{border-color:var(--g);}
.btn-confirmar{width:100%;padding:14px;background:linear-gradient(135deg,var(--gd),var(--g));color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;font-family:'Syne',sans-serif;}
.btn-confirmar:disabled{background:#9ca3af;}
.sector-card{background:#fff;border-radius:14px;padding:12px 14px;box-shadow:0 2px 8px rgba(0,0,0,.06);border-left:4px solid var(--g);cursor:pointer;}
.sector-prog{height:4px;background:#e2e8f0;border-radius:99px;overflow:hidden;margin-top:6px;}
.sector-prog-f{height:100%;background:linear-gradient(90deg,var(--g),#22c55e);border-radius:99px;}
.upload-box{border:2px dashed var(--bdr);border-radius:10px;padding:20px;text-align:center;cursor:pointer;}
.upload-box input{display:none;}
.upload-preview{max-width:100%;border-radius:8px;margin-top:10px;display:none;}
.hist-card{background:#fff;border-radius:14px;padding:12px;box-shadow:0 2px 10px rgba(0,0,0,.06);display:flex;align-items:center;gap:10px;}
.contact-card{background:#fff;border-radius:16px;padding:18px;box-shadow:0 2px 12px rgba(0,0,0,.06);display:flex;align-items:center;gap:14px;cursor:pointer;}
.nav{background:#fff;border-top:2px solid var(--bdr);display:flex;flex-shrink:0;}
.nav-btn{flex:1;padding:9px 4px;background:none;border:none;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:2px;font-size:10px;color:var(--mut);font-family:'DM Sans',sans-serif;font-weight:600;}
.nav-btn.active{color:var(--g);}
.nav-btn span:first-child{font-size:20px;}
.cart-btn{position:relative;background:linear-gradient(135deg,var(--gd),var(--g));color:#fff;border:none;border-radius:10px;padding:6px 12px;font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:5px;}
.cart-badge{position:absolute;top:-6px;right:-6px;background:#dc2626;color:#fff;font-size:10px;font-weight:900;width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;border:2px solid #fff;display:none;}
.empty{text-align:center;color:var(--mut);padding:40px 20px;}
.empty span{font-size:48px;display:block;margin-bottom:10px;}
.loading{display:flex;flex-direction:column;align-items:center;justify-content:center;flex:1;gap:10px;color:var(--mut);padding:40px;}
.spinner{width:32px;height:32px;border:3px solid var(--gb);border-top-color:var(--g);border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
#toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(20px);background:#0f172a;color:#fff;padding:10px 20px;border-radius:99px;font-size:13px;font-weight:600;opacity:0;transition:all .3s;pointer-events:none;z-index:999;white-space:nowrap;}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>
<div id="shell">
  <div class="hdr">
    <div class="logo">
      <div class="logo-ic">🛒</div>
      <div>
        <div class="logo-t">Gru<b>Pay</b></div>
        <div class="logo-s">COMPRA EN GRUPO · AHORRA</div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
      <button class="cart-btn" onclick="goScreen('carrito')" id="hdr-cart" style="display:none;">
        🛒 <span class="cart-badge" id="cart-badge">0</span>
      </button>
      <div id="hdr-btns" style="display:flex;gap:6px;">
        <button onclick="goScreen('login')" style="padding:6px 12px;border-radius:99px;border:2px solid var(--bdr);background:#fff;font-size:11px;font-weight:700;cursor:pointer;">Ingresar</button>
      </div>
      <div id="hdr-user" style="display:none;align-items:center;gap:8px;">
        <div id="hdr-nombre" style="background:var(--gl);border:1.5px solid var(--gb);color:var(--gd);font-size:11px;font-weight:700;padding:4px 10px;border-radius:99px;"></div>
        <button onclick="cerrarSesion()" style="background:none;border:none;font-size:11px;color:var(--mut);cursor:pointer;">Salir</button>
      </div>
    </div>
  </div>

  <!-- INICIO -->
  <div class="screen active" id="screen-inicio">
    <div class="hero">
      <div class="hero-tag">🇵🇪 MERCADO PERUANO · LA PARADA</div>
      <div class="hero-title">Compra solo o <span>junta tu grupo</span> 💸</div>
      <div class="hero-pills">
        <div class="pill">🛒 Compra individual disponible</div>
        <div class="pill">👥 5 personas = 10% OFF</div>
        <div class="pill">🚚 Entrega en tu sector</div>
      </div>
      <div class="hero-cta" id="hero-guest">
        <button class="btn-hero-primary" onclick="goScreen('login');switchTab('registro')">🤖 Crear cuenta</button>
        <button class="btn-hero-sec" onclick="goScreen('login')">🔑 Iniciar sesión</button>
      </div>
      <div id="hero-user" style="display:none;background:rgba(255,255,255,.15);border-radius:12px;padding:12px;border:1px solid rgba(255,255,255,.2);">
        <div style="font-family:'Syne',sans-serif;font-size:15px;font-weight:900;color:#fff;margin-bottom:8px;">👋 Hola, <span id="hero-nombre"></span>!</div>
        <div style="display:flex;gap:8px;">
          <button onclick="goScreen('carrito')" style="flex:1;padding:9px;background:#fff;color:#14532d;border:none;border-radius:10px;font-size:12px;font-weight:800;cursor:pointer;">🛒 Mi carrito</button>
          <button onclick="goScreen('pedidos')" style="flex:1;padding:9px;background:rgba(255,255,255,.2);color:#fff;border:1.5px solid rgba(255,255,255,.3);border-radius:10px;font-size:12px;font-weight:700;cursor:pointer;">📦 Mis pedidos</button>
        </div>
      </div>
    </div>
    <div class="scroll-body">
      <div>
        <div class="sec-row" style="margin-bottom:10px;">
          <div class="sec-t">🗂 Productos</div>
          <div class="sec-count" id="hs-g">cargando...</div>
        </div>
        <div class="cat-row">
          <div class="cat-btn on" onclick="selCat('todas',this)"><span>🛒</span><span>Todos</span></div>
          <div class="cat-btn" onclick="selCat('frutas',this)"><span>🍓</span><span>Frutas</span></div>
          <div class="cat-btn" onclick="selCat('lacteos',this)"><span>🧀</span><span>Lácteos</span></div>
          <div class="cat-btn" onclick="selCat('postres',this)"><span>🍬</span><span>Snacks</span></div>
        </div>
      </div>
      <div id="inicio-body">
        <div class="loading"><div class="spinner"></div><span>Cargando productos...</span></div>
      </div>
    </div>
  </div>

  <!-- SECTORES -->
  <div class="screen" id="screen-sectores">
    <div class="checkout-hdr">
      <button class="checkout-back" onclick="goScreen('inicio')">←</button>
      <div class="checkout-title" id="sect-title">Grupos</div>
    </div>
    <div class="scroll-body">
      <div id="sect-desc-box"></div>
      <div id="sectores-list"></div>
      <button class="btn-confirmar" onclick="mostrarFormNuevoSector()" style="margin-top:4px;">➕ Crear grupo en mi sector</button>
      <div id="form-nuevo-sector"></div>
    </div>
  </div>

  <!-- CHECKOUT -->
  <div class="screen" id="screen-checkout">
    <div class="checkout-hdr">
      <button class="checkout-back" onclick="goScreen('sectores')">←</button>
      <div class="checkout-title" id="checkout-title">Confirmar pedido</div>
    </div>
    <div style="flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:12px;">
      <div id="tipo-compra-banner"></div>
      <div class="form-card">
        <div style="font-family:'Syne',sans-serif;font-size:14px;font-weight:900;margin-bottom:12px;">👤 Tus datos</div>
        <label class="form-label">NOMBRE COMPLETO</label>
        <input class="form-input" id="c-nombre" placeholder="Juan Pérez" style="margin-bottom:10px;">
        <label class="form-label">WHATSAPP</label>
        <input class="form-input" id="c-tel" placeholder="9XX XXX XXX" type="tel" style="margin-bottom:10px;">
        <label class="form-label">SECTOR / URBANIZACIÓN</label>
        <input class="form-input" id="c-sector" placeholder="Ej: Huachipa...">
      </div>
      <div class="form-card">
        <div style="font-family:'Syne',sans-serif;font-size:14px;font-weight:900;margin-bottom:10px;">🛒 Tu pedido</div>
        <div id="resumen-items"></div>
      </div>
      <div id="desc-info-box"></div>
      <div class="form-card">
        <div style="font-family:'Syne',sans-serif;font-size:14px;font-weight:900;margin-bottom:10px;">📸 Comprobante de pago</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;">
          <div style="background:var(--gl);border:1.5px solid var(--gb);border-radius:10px;padding:10px;text-align:center;"><div style="font-size:20px;">💜</div><div style="font-size:11px;font-weight:700;color:var(--gd);">Yape/Plin</div><div style="font-size:10px;color:var(--mut);">948-115-030</div></div>
          <div style="background:var(--gl);border:1.5px solid var(--gb);border-radius:10px;padding:10px;text-align:center;"><div style="font-size:20px;">🍋</div><div style="font-size:11px;font-weight:700;color:var(--gd);">Lemon/Interbank</div><div style="font-size:10px;color:var(--mut);">Cuenta de ahorro</div></div>
        </div>
        <div class="upload-box" onclick="document.getElementById('file-input').click()">
          <div style="font-size:28px;margin-bottom:6px;">📎</div>
          <div style="font-size:13px;font-weight:600;">Subir captura de Yape</div>
          <div style="font-size:11px;color:var(--mut);">JPG, PNG o WebP</div>
          <input type="file" id="file-input" accept="image/*" onchange="previewFile(this)">
          <img class="upload-preview" id="upload-preview">
        </div>
      </div>
      <button class="btn-confirmar" id="btn-confirmar" onclick="confirmarPedido()">✅ Confirmar pedido</button>
    </div>
  </div>

  <!-- CARRITO -->
  <div class="screen" id="screen-carrito">
    <div class="checkout-hdr">
      <button class="checkout-back" onclick="goScreen('inicio')">←</button>
      <div class="checkout-title">🛒 Mi carrito</div>
    </div>
    <div class="scroll-body" id="carrito-body"></div>
  </div>

  <!-- PEDIDOS -->
  <div class="screen" id="screen-pedidos">
    <div class="scroll-body">
      <div class="sec-t" style="padding:4px 0 12px;">📦 Mis pedidos</div>
      <div id="hist-body"><div class="empty"><span>📭</span>Aún no tienes pedidos</div></div>
    </div>
  </div>

  <!-- CONTACTO -->
  <div class="screen" id="screen-contacto">
    <div class="scroll-body">
      <div class="sec-t" style="padding:4px 0 12px;">📞 Soporte</div>
      <div class="contact-card" onclick="window.open('https://wa.me/51948115030?text=Hola Karla, necesito soporte GruPay','_blank')">
        <div style="width:46px;height:46px;border-radius:12px;background:linear-gradient(135deg,#14532d,#16a34a);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">🤖</div>
        <div style="flex:1;"><div style="font-weight:700;font-size:14px;">Karla — Asistente GruPay</div><div style="font-size:12px;color:var(--mut);">Ayuda 24/7 · WhatsApp</div></div>
        <div style="color:var(--mut);font-size:18px;">›</div>
      </div>
      <div class="contact-card" onclick="window.open('https://wa.me/51948115030','_blank')" style="margin-top:10px;">
        <div style="width:46px;height:46px;border-radius:12px;background:#dcfce7;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">💬</div>
        <div style="flex:1;"><div style="font-weight:700;font-size:14px;">WhatsApp Directo</div><div style="font-size:12px;color:var(--mut);">+51 948 115 030</div></div>
        <div style="color:var(--mut);font-size:18px;">›</div>
      </div>
    </div>
  </div>

  <!-- LOGIN -->
  <div class="screen" id="screen-login">
    <div class="scroll-body">
      <div style="text-align:center;padding:20px 0 10px;">
        <div style="font-size:48px;margin-bottom:8px;">🛒</div>
        <div style="font-family:'Syne',sans-serif;font-size:22px;font-weight:900;">Gru<span style="color:var(--g)">Pay</span></div>
      </div>
      <div style="display:flex;gap:0;margin-bottom:16px;border:2px solid var(--bdr);border-radius:12px;overflow:hidden;">
        <button id="tab-login" onclick="switchTab('login')" style="flex:1;padding:10px;font-size:13px;font-weight:700;border:none;background:var(--gd);color:#fff;cursor:pointer;">Iniciar sesión</button>
        <button id="tab-registro" onclick="switchTab('registro')" style="flex:1;padding:10px;font-size:13px;font-weight:700;border:none;background:#fff;color:var(--mut);cursor:pointer;">Crear cuenta</button>
      </div>
      <div id="panel-login" class="form-card">
        <label class="form-label">TU NÚMERO WHATSAPP</label>
        <div style="display:flex;gap:8px;margin-bottom:14px;">
          <div style="background:#f1f5f9;border:2px solid var(--bdr);border-radius:10px;padding:11px 13px;font-size:15px;font-weight:700;color:var(--mut);">+51</div>
          <input class="form-input" id="login-tel" placeholder="9XX XXX XXX" type="tel" style="flex:1;" oninput="this.value=this.value.replace(/\D/g,'').slice(0,9)">
        </div>
        <button class="btn-confirmar" onclick="verificarUsuario()">Ingresar →</button>
        <div id="login-msg" style="text-align:center;font-size:12px;margin-top:10px;display:none;"></div>
      </div>
      <div id="panel-registro" class="form-card" style="display:none;">
        <label class="form-label">NOMBRE COMPLETO</label>
        <input class="form-input" id="reg-nombre" placeholder="Juan Pérez" style="margin-bottom:12px;">
        <label class="form-label">WHATSAPP</label>
        <div style="display:flex;gap:8px;margin-bottom:12px;">
          <div style="background:#f1f5f9;border:2px solid var(--bdr);border-radius:10px;padding:11px 13px;font-size:15px;font-weight:700;color:var(--mut);">+51</div>
          <input class="form-input" id="reg-tel" placeholder="9XX XXX XXX" type="tel" style="flex:1;" oninput="this.value=this.value.replace(/\D/g,'').slice(0,9)">
        </div>
        <label class="form-label">DIRECCIÓN DE ENTREGA</label>
        <input class="form-input" id="reg-direccion" placeholder="Jr. Los Cactus 340" style="margin-bottom:12px;">
        <label class="form-label">REFERENCIA</label>
        <input class="form-input" id="reg-referencia" placeholder="Puerta azul, piso 2" style="margin-bottom:12px;">
        <label class="form-label">HORARIO PREFERIDO</label>
        <select class="form-input" id="reg-horario" style="margin-bottom:14px;">
          <option value="">Selecciona...</option>
          <option>🌅 Mañana (8am - 12pm)</option>
          <option>☀️ Mediodía (12pm - 3pm)</option>
          <option>🌆 Tarde (3pm - 7pm)</option>
          <option>✅ Cualquier horario</option>
